{
  "name": "cognivo-ai-backend",
  "version": "1.0.0",
  "description": "Backend API for Cognivo AI multi-model chat platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "type-check": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["ai", "chat", "api", "backend"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.0",
    "axios": "^1.5.0",
    "openai": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.1.6",
    "@types/express": "^4.17.17",
    "@types/node": "^20.5.0",
    "@types/cors": "^2.8.14",
    "@types/bcryptjs": "^2.4.2",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "eslint": "^8.48.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "prettier": "^3.0.3"
  }
}